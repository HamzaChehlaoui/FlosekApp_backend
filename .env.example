# ============================================
# ENVIRONMENT VARIABLES FOR FLOSEK
# ============================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to git!

# ============================================
# SERVER CONFIGURATION
# ============================================
SERVER_PORT=8081

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=flosek_db
DB_USERNAME=flosek_user
DB_PASSWORD=flosek_secure_password_2026

# ============================================
# JWT CONFIGURATION
# ============================================
# IMPORTANT: Generate a strong random secret for production!
# Example: openssl rand -base64 64
JWT_SECRET=flosek-super-secret-key-change-in-production-2026-please-use-strong-random-value
JWT_EXPIRATION=86400000

# ============================================
# JPA/HIBERNATE CONFIGURATION
# ============================================
# Options: create, create-drop, update, validate, none
DDL_AUTO=update
SHOW_SQL=true

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Options: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

